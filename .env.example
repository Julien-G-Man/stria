OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Storage — leave blank for local SQLite
DATABASE_URL=

# SQLite path (only used when DATABASE_URL is not set)
SQLITE_DB_PATH=stria/data/stria.sqlite3

# Pipeline tuning
MIN_CONFIDENCE=0.70
BLUR_VARIANCE_THRESHOLD=80.0
MAX_IMAGE_SIZE_MB=10

# Data directory
DATA_DIR=stria/data

# Set in production to enable JSON logging
# PORT=8000
